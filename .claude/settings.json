{
  "permissions": {
    "allow": [
      "Bash(git add:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-git.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
